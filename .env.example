# Copy to .env for local dev, or paste each as env vars on Render.
# Never commit a real .env — it's already in .gitignore.

# --- Database ---
# Local dev (SQLite, fine for one person on one machine):
DATABASE_URL=sqlite:///./cpa.db
# Production (Neon Postgres — get from neon.tech dashboard):
# DATABASE_URL=postgresql://user:pwd@ep-xxx.eu-central-1.aws.neon.tech/cpa?sslmode=require

# --- Auth ---
# Generate a strong one with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-in-production-this-is-not-secret

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=False

# --- CORS ---
# Local dev — accept anything:
CORS_ORIGINS=*
# Production — lock to your Vercel URL (no trailing slash):
# CORS_ORIGINS=https://cpa-xyz.vercel.app

# --- File upload ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800
